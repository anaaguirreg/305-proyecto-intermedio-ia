  "copy_es": {
    "act_disclaimer": "Los datos forenses describen la población de casos peritados por Medicina Legal 2018–2024 en cuatro departamentos del Pacífico colombiano. No representan la totalidad de hechos ocurridos. El subregistro estructural es especialmente alto en zonas de difícil acceso.",
    "sub_acto_4_1": {
      "title": "El universo peritado",
      "anchor": "34.079 casos peritados por Medicina Legal entre 2018 y 2024 en Cauca, Chocó, Nariño y Valle del Cauca. Más de la mitad de las víctimas son niñas, niños y adolescentes."
    },
    "sub_acto_4_2": {
      "title": "El hogar como escenario",
      "anchor": "En más del 77% de los casos peritados, el hecho ocurrió en el hogar. El espacio que debería ser refugio es el escenario más frecuente de la violencia.",
      "axis_labels_es": {
        "day_label": "Día de la semana",
        "month_label": "Mes",
        "value_label": "Número de casos",
        "scenario_label": "Escenario del hecho",
        "pct_label": "% del total del dataset"
      },
      "panel_titles_es": {
        "heatmap_vif": "PROVISIONAL: Violencia intrafamiliar por día y mes",
        "heatmap_sexual": "PROVISIONAL: Violencia sexual por día y mes",
        "escenario": "PROVISIONAL: Escenario del hecho — VIF vs Sexual"
      },
      "selector_labels_es": {
        "label": "Departamento",
        "regional": "Regional"
      },
      "caveat_choco_es": {
        "heatmap_vif": "PROVISIONAL: n=213 casos, insuficiente para conclusiones robustas sobre patrones temporales. El bajo volumen puede reflejar subregistro de acceso a medicina legal en zonas rurales del departamento.",
        "heatmap_sexual": "PROVISIONAL: NO_REGISTRADO alcanza 43% en hora y 8% en escenario — indicador de barreras de reporte.",
        "escenario": "PROVISIONAL: 7.95% de los casos DS3 en Chocó tienen escenario NO_REGISTRADO, el mayor de la región. Los porcentajes reflejan solo los casos con escenario documentado."
      }
    },
    "sub_acto_4_3": {
      "title": "Dos violencias, dos universos de agresores",
      "anchor": "Dos violencias, dos universos de agresores. La violencia sexual viene del conocido — padrastro, amigo, vecino. La violencia física intrafamiliar viene del propio núcleo — hijo, hermano, padre. La edad de la víctima define quién la agrede; el tipo de violencia define desde dónde."
    },
    "sub_acto_4_4": {
      "title": "El factor declarado y la circunstancia",
      "anchor": "El peritaje forense registra el factor precipitante de la violencia física y la circunstancia de la violencia sexual. En el 65% de los casos de VIF, el factor declarado es la intolerancia y el machismo.",
      "ds4_title": "¿Qué declara el peritaje como factor de la violencia física (VIF)?",
      "ds3_title": "¿Bajo qué circunstancia ocurrió la violencia sexual?"
    },
    "sub_acto_4_5": {
      "title": "Lo que el peritaje no captura",
      "anchor_text": "En una región donde Chocó es mayoritariamente afrocolombiano y Cauca alberga territorios ancestrales Nasa y Misak, Medicina Legal registra que solo el {pct_afro}% de las mujeres peritadas por delito sexual se identifica como Afro-NARP y el {pct_ind}% como Indígena. El resto — {pct_sin}% — figura como 'sin pertenencia declarada'. No es que la violencia no toque a estas comunidades: es que el sistema forense no las reconoce.",
      "anchor_disability": "El {pct_disc_ds4}% de las víctimas femeninas de VIF y el {pct_disc_ds3}% de las de delito sexual peritadas tienen condición de discapacidad registrada. Piso mínimo, no realidad.",
      "caveat": "El subregistro étnico en Medicina Legal es estructural: la variable 'pertenencia étnica' depende del autorreconocimiento en el momento del peritaje, sin protocolo diferencial. Chocó tiene la cobertura forense más baja de la región (n=312 casos VIF en 7 años); no leer estos porcentajes como composición étnica real, sino como evidencia del silencio institucional.",
      "low_n_note": "Categorías marcadas con * tienen menos de 30 casos femeninos; se muestran por transparencia pero no permiten inferencia."
    }
  },
