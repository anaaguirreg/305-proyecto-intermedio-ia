  "format_rules": {
    "cod_municipio": {
      "keep_digits_only": true,
      "target_length": 5,
      "pad_with": "0"
    }
  },
  "age_aggregation": {
    "regex_pattern": "(MUJERES|HOMBRES).*\\d+",
    "target_columns": {
      "pob_f_0_17": {
        "gender_keyword": "MUJERES",
        "min_age": 0,
        "max_age": 17
      },
      "pob_f_18_mas": {
        "gender_keyword": "MUJERES",
        "min_age": 18,
        "max_age": 101
      },
      "pob_h_0_17": {
        "gender_keyword": "HOMBRES",
        "min_age": 0,
        "max_age": 17
      },
      "pob_h_18_mas": {
        "gender_keyword": "HOMBRES",
        "min_age": 18,
        "max_age": 101
      }
    },
    "sanity_check": {
      "tolerance_pct": 0.001,
      "f_base_col": "TOTAL Mujeres",
      "h_base_col": "TOTAL Hombres"
    }
  },
  "quarantine_config": {
    "critical_columns_for_filter": ["fecha_hecho", "cod_municipio", "departamento"],
    "output_dir": "docs",
    "filename_pattern": "quarantine_{dataset}_{column}_null.csv"
  },
  "cleaning_config": {
    "critical_columns": {
      "cantidad": ["CANTIDAD", "NUMERO_CASOS", "TOTAL_VICTIMAS"],
      "genero_victima": ["GENERO", "SEXO", "GENERO_VICTIMA"],
      "grupo_etario": ["GRUPO_ETARIO", "RANGO_EDAD", "GRUPOEDAD"],
      "tipo_delito": ["DELITO", "delito", "TIPO_DELITO", "NOMBRE_DELITO"]
    },
    "imputation_rules": {
      "cantidad": {
        "null_value": 0,
        "negative_to_zero": true
      },
      "genero_victima": {
        "null_value": "NO_REGISTRADO"
      },
      "grupo_etario": {
        "null_value": "NO_REGISTRADO"
      }
    },
    "deduplication_rules": {
      "drop_exact_mirror_duplicates": true,
      "quarantine_filename_pattern": "cuarentena_duplicados_{dataset}.csv"
    }
  },
