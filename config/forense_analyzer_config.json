  "ds4_config": {
    "_comment": "Sección 6.2 — Tablas derivadas de DS4 (VIF forense)",
    "dataset_key": "forense",
    "description": "VIF forense — Medicina Legal. Solo agresores intrafamiliares (18 categorías). Variable específica: factor (9 categorías).",
    "columns_available": [
      "anio_hecho",
      "genero_victima",
      "ciclo_vital",
      "grupo_edad",
      "cod_municipio",
      "municipio",
      "departamento",
      "escenario",
      "agresor",
      "sexo_agresor",
      "factor",
      "discapacidad",
      "etnia",
      "hora_rango",
      "mes_hecho",
      "dia_hecho",
      "dias_incapacidad",
      "dimension_agresor",
      "dimension_escenario",
      "dimension_discapacidad",
      "dimension_etnia"
    ],
    "count_column": "_count",
    "count_method": "size",
    "tables": {
      "ds4_municipio_resumen": {
        "_comment": "Resumen de VIF forense por municipio para fichas municipales",
        "granularity": "1 fila × municipio",
        "destination": "ficha_municipal",
        "groupby": [
          "cod_municipio",
          "municipio",
          "departamento"
        ],
        "aggregations": {
          "total_casos": {
            "method": "size"
          },
          "pct_femenino": {
            "column": "genero_victima",
            "method": "value_counts_pct",
            "value": "FEMENINO"
          },
          "pct_nna_femenino": {
            "method": "conditional_pct",
            "conditions": {
              "genero_victima": "FEMENINO",
              "grupo_edad": "A MENORES DE EDAD 18 ANOS"
            }
          },
          "pct_adultas_femenino": {
            "method": "conditional_pct",
            "conditions": {
              "genero_victima": "FEMENINO",
              "grupo_edad": "B MAYORES DE EDAD 18 ANOS"
            }
          },
          "agresor_frecuente_nna_f": {
            "column": "agresor",
            "method": "filtered_mode",
            "filters": {
              "genero_victima": "FEMENINO",
              "grupo_edad": "A MENORES DE EDAD 18 ANOS"
            }
          },
          "agresor_frecuente_adultas_f": {
            "column": "agresor",
            "method": "filtered_mode",
            "filters": {
              "genero_victima": "FEMENINO",
              "grupo_edad": "B MAYORES DE EDAD 18 ANOS"
            }
          },
          "agresor_frecuente": {
            "column": "agresor",
            "method": "mode"
          },
          "dimension_agresor_frecuente": {
            "column": "dimension_agresor",
            "method": "mode"
          },
          "escenario_frecuente": {
            "column": "escenario",
            "method": "mode"
          },
          "dimension_escenario_frecuente": {
            "column": "dimension_escenario",
            "method": "mode"
          },
          "factor_mas_frecuente": {
            "column": "factor",
            "method": "mode"
          }
        },
        "output_filename": "ds4_municipio_resumen.parquet"
      },
      "ds4_agresor": {
        "_comment": "Continuo multigeneracional VIF forense — agresor granular × ciclo vital, filtrado a víctimas FEMENINO. dimension_agresor como columna atributo derivada.",
        "granularity": "departamento + agresor + ciclo_vital (FEMENINO)",
        "destination": "visualizacion_agresor",
        "pre_filter": {
          "genero_victima": "FEMENINO"
        },
        "groupby": [
          "departamento",
          "agresor",
          "ciclo_vital"
        ],
        "aggregations": {
          "n_casos": {
            "method": "size"
          },
          "pct_total": {
            "method": "pct_of_group",
            "group_level": "departamento"
          }
        },
        "attribute_columns": {
          "dimension_agresor": "agresor"
        },
        "output_filename": "ds4_agresor.parquet"
      },
      "ds4_escenario": {
        "_comment": "Distribución de escenarios donde ocurre la VIF (víctimas FEMENINO)",
        "granularity": "departamento + dimension_escenario (FEMENINO)",
        "destination": "visualizacion_escenario",
        "pre_filter": {
          "genero_victima": "FEMENINO"
        },
        "groupby": [
          "departamento",
          "dimension_escenario"
        ],
        "aggregations": {
          "n_casos": {
            "method": "size"
          },
          "pct_total": {
            "method": "pct_of_group",
            "group_level": "departamento"
          }
        },
        "output_filename": "ds4_escenario.parquet"
      },
      "ds4_factor": {
        "_comment": "Distribución de factores desencadenantes (variable exclusiva de DS4, víctimas FEMENINO)",
        "granularity": "departamento + factor (FEMENINO)",
        "destination": "visualizacion_factor",
        "pre_filter": {
          "genero_victima": "FEMENINO"
        },
        "groupby": [
          "departamento",
          "factor"
        ],
        "aggregations": {
          "n_casos": {
            "method": "size"
          },
          "pct_total": {
            "method": "pct_of_group",
            "group_level": "departamento"
          }
        },
        "output_filename": "ds4_factor.parquet"
      },
      "ds4_temporalidad": {
        "_comment": "Heatmap de estacionalidad de la VIF por departamento (víctimas FEMENINO) — departamento como dimensión para filtrado interactivo en frontend",
        "granularity": "departamento + mes + dia_hecho + hora_rango (FEMENINO)",
        "destination": "heatmap_temporal",
        "pre_filter": {
          "genero_victima": "FEMENINO"
        },
        "groupby": [
          "departamento",
          "mes_hecho",
          "dia_hecho",
          "hora_rango"
        ],
        "aggregations": {
          "n_casos": {
            "method": "size"
          }
        },
        "output_filename": "ds4_temporalidad.parquet"
      },
      "ds4_interseccional": {
        "_comment": "Análisis de vulnerabilidad múltiple en VIF",
        "granularity": "ciclo_vital + dimension_etnia + dimension_discapacidad",
        "destination": "analisis_interseccional",
        "groupby": [
          "ciclo_vital",
          "dimension_etnia",
          "dimension_discapacidad"
        ],
        "aggregations": {
          "n_casos": {
            "method": "size"
          },
          "pct_femenino": {
            "column": "genero_victima",
            "method": "value_counts_pct",
            "value": "FEMENINO"
          }
        },
        "output_filename": "ds4_interseccional.parquet"
      }
    }
  },
